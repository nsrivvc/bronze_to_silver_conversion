# --- Database connection (local/dummy Postgres for the prototype) ---
# Either set DATABASE_URL directly...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pipeline
# ...or leave it blank and set the parts below instead:
# PGUSER=postgres
# PGPASSWORD=postgres
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=pipeline

# --- Schemas (override if your raw/curated schemas are named differently) ---
BRONZE_SCHEMA=bronze
SILVER_SCHEMA=silver

# --- Logging ---
LOG_LEVEL=INFO
